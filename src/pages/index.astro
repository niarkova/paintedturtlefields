---
import { getCollection } from 'astro:content';
import GardenApp from '../components/GardenApp';
import '../styles/tokens.css';
import '../styles/app.css';

// Load stops from markdown files — 5 stops in walking order: 3→4→2→8→7
const WALKING_ORDER = [3, 4, 2, 8, 7];
const stopEntries = await getCollection('stops');
const stops = WALKING_ORDER.map((num, walkIdx) => {
  const entry = stopEntries.find((e) => e.data.number === num);
  if (!entry) throw new Error(`No stop entry found for number ${num} (walking order index ${walkIdx})`);
  return {
    id: entry.id.replace(/^\d+-/, ''),
    n: walkIdx + 1,
    title: entry.data.name,
    mood: entry.data.subtitle,
    desc: entry.body?.trim() ?? '',
    plants: entry.data.plants,
    accent: entry.data.accent ?? '#D88B6A',
  };
});

// Goals come from the Google Sheet via the Apps Script API; start empty
const seedGoals: { id: string; text: string; name?: string }[] = [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content="A peaceful walk through Painted Turtle Fields in Underhill, Vermont. Garden tour July 11, 2026." />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,200..900;1,8..60,200..900&family=Young+Serif&display=swap"
      rel="stylesheet"
    />
    <title>Painted Turtle Fields — July 11, 2026</title>
    <style>
      /* Ensure the app fills the viewport */
      html, body { margin: 0; padding: 0; height: 100%; overflow: hidden; }
      #app { height: 100%; }
    </style>
  </head>
  <body>
    <div id="app">
      <GardenApp client:only="react" stops={stops} seedGoals={seedGoals} />
    </div>
  </body>
</html>
