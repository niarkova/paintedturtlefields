---
import { getCollection } from 'astro:content';
import GardenApp from '../components/GardenApp';
import '../styles/tokens.css';
import '../styles/app.css';

// Load stops from markdown files — 5 stops in walking order: 3→4→2→8→7
const WALKING_ORDER = [3, 4, 2, 8, 7];
const stopEntries = await getCollection('stops');
const stops = WALKING_ORDER.map((num, walkIdx) => {
  const entry = stopEntries.find((e) => e.data.number === num);
  if (!entry) throw new Error(`No stop entry found for number ${num} (walking order index ${walkIdx})`);
  return {
    id: entry.id.replace(/^\d+-/, ''),
    n: walkIdx + 1,
    title: entry.data.name,
    mood: entry.data.subtitle,
    desc: entry.body?.trim() ?? '',
    plants: entry.data.plants,
    accent: entry.data.accent ?? '#D88B6A',
  };
});

// Goals come from the Google Sheet via the Apps Script API; start empty
const seedGoals: { id: string; text: string; name?: string }[] = [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content="A peaceful walk through Painted Turtle Fields in Underhill, Vermont. Garden tour July 11, 2026." />
    <meta name="robots" content="noindex, nofollow" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Painted Turtle Fields" />
    <meta property="og:description" content="A peaceful walk through Painted Turtle Fields in Underhill, Vermont. Garden tour July 11, 2026." />
    <meta property="og:image" content="/og-image.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Painted Turtle Fields" />
    <meta name="twitter:description" content="A peaceful walk through Painted Turtle Fields in Underhill, Vermont. Garden tour July 11, 2026." />
    <meta name="twitter:image" content="/og-image.jpg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <!-- Preload the intro's critical art so it paints fast on slow (3G) links -->
    <link rel="preload" as="image" href="/assets/textures/watercolor-paper-dark-green.webp" />
    <link rel="preload" as="image" href="/assets/watercolor/painted-turtle.webp" />
    <!-- Preload the map so screen 2 paints instantly after the intro -->
    <link rel="preload" as="image" href="/assets/map-ground-v2.webp" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Subset to the weights/styles actually used (400–700, normal + italic) -->
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400..700;1,8..60,400..700&family=Young+Serif&display=swap"
      rel="stylesheet"
    />
    <title>Painted Turtle Fields</title>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-PYQLW97H9Z"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-PYQLW97H9Z');
    </script>
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }
    </script>
    <style>
      /* Ensure the app fills the viewport */
      html, body { margin: 0; padding: 0; height: 100%; overflow: hidden; }
      /* Forest backdrop from first paint so there's no white flash before
         the React loader (turtle) mounts. */
      body { background: #0E2318; }
      #app { height: 100%; }
    </style>
  </head>
  <body>
    <div id="app">
      <GardenApp client:only="preact" stops={stops} seedGoals={seedGoals} />
    </div>
  </body>
</html>
