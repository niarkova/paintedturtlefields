---
import WildlifeCard from './WildlifeCard.astro';

interface WildlifeItem {
  id: string;
  name: string;
  note: string;
  img: string;
  glow: string;
}
interface Props {
  wildlife: WildlifeItem[];
}
const { wildlife } = Astro.props;
---
<section class="wildlife-section" aria-label="Spotted wildlife">
  <div class="section-inner--wide">
    <div class="section-heading reveal">
      <span class="kicker">wild neighbors</span>
      <h2>Spotted <em>wildlife</em></h2>
      <p style="font-family:var(--font-script);font-size:20px;color:var(--cream-ink-soft);margin-top:8px;">
        we share this space — keep your eyes open
      </p>
    </div>
    <p style="font-family:var(--font-body);font-size:var(--text-body);max-width:58ch;line-height:1.65;color:var(--cream-ink-soft);">
      The garden borders a wetland. Turtles nest here. The foxes have a den nearby.
      Bees are everywhere — the real heartbeat of this place.
      Tap each creature when you spot one today.
    </p>

    <div class="wildlife-grid" role="group" aria-label="Wildlife spotting">
      {wildlife.map(w => <WildlifeCard {...w} />)}
    </div>

    <p id="wildlife-count" class="spotted-banner" aria-live="polite"></p>
  </div>
</section>
