---
interface StopItem {
  id: string;
  number: number;
  name: string;
  subtitle: string;
  mapLabel?: string;
}
interface Props {
  stops: StopItem[];
}
const { stops } = Astro.props;

// Vertical serpentine path — stops alternate left / right, top to bottom
// ViewBox: 0 0 300 510  (20px padding top & bottom beyond node range)
const LX = 65;   // left column x
const RX = 235;  // right column x
const nodeY = [50, 115, 180, 245, 310, 375, 430, 480];

// Node positions: even indices → left, odd → right
const approxNodes = nodeY.map((y, i) => ({ x: i % 2 === 0 ? LX : RX, y }));

// Cubic bezier serpentine:
//   L→R segment: CP1=(RX, y_start), CP2=(LX, y_end)  → horizontal tangents at both ends
//   R→L segment: CP1=(LX, y_start), CP2=(RX, y_end)  → horizontal tangents at both ends
const PATH_D = [
  `M ${LX},${nodeY[0]}`,
  `C ${RX},${nodeY[0]} ${LX},${nodeY[1]} ${RX},${nodeY[1]}`,   // 1 → 2  (L→R)
  `C ${LX},${nodeY[1]} ${RX},${nodeY[2]} ${LX},${nodeY[2]}`,   // 2 → 3  (R→L)
  `C ${RX},${nodeY[2]} ${LX},${nodeY[3]} ${RX},${nodeY[3]}`,   // 3 → 4  (L→R)
  `C ${LX},${nodeY[3]} ${RX},${nodeY[4]} ${LX},${nodeY[4]}`,   // 4 → 5  (R→L)
  `C ${RX},${nodeY[4]} ${LX},${nodeY[5]} ${RX},${nodeY[5]}`,   // 5 → 6  (L→R)
  `C ${LX},${nodeY[5]} ${RX},${nodeY[6]} ${LX},${nodeY[6]}`,   // 6 → 7  (R→L)
  `C ${RX},${nodeY[6]} ${LX},${nodeY[7]} ${RX},${nodeY[7]}`,   // 7 → 8  (L→R)
].join(' ');
---

<svg
  class="map-svg"
  viewBox="0 0 300 510"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  focusable="false"
  id="gardenMapSvg"
>
  <!-- Subtle garden-area blobs for spatial context -->
  {approxNodes.map((node, i) => (
    <ellipse
      class="map-garden-area"
      cx={node.x}
      cy={node.y}
      rx={i % 2 === 0 ? 34 : 30}
      ry="20"
    />
  ))}

  <!-- Full route path (static, decorative) -->
  <path class="map-path-bg" id="mapPathBg" d={PATH_D} />

  <!-- Stop nodes + labels -->
  {stops.map((s, i) => {
    const isLeft  = i % 2 === 0;
    const nodeX   = approxNodes[i].x;
    const nodeYv  = approxNodes[i].y;
    const labelX  = isLeft ? nodeX + 16 : nodeX - 16;
    const anchor  = isLeft ? 'start' : 'end';
    const label   = s.mapLabel ?? s.name;
    return (
      <>
        <g
          class="map-node"
          id={`map-node-${s.id}`}
          data-stop-idx={String(i)}
          data-stop-id={s.id}
          data-stop-name={s.name}
          transform={`translate(${nodeX}, ${nodeYv})`}
          tabindex="0"
          role="button"
          aria-label={`View stop ${s.number}: ${s.name}`}
        >
          <circle class="map-node-ring" r="12" />
          <text class="map-node-num">{s.number}</text>
        </g>
        <text
          class="map-node-label"
          x={labelX}
          y={nodeYv}
          text-anchor={anchor}
          dominant-baseline="central"
          aria-hidden="true"
        >{label}</text>
      </>
    );
  })}
</svg>
