---
import PlantChip from './ui/PlantChip.astro';
import LikeButton from './ui/LikeButton.astro';

interface Props {
  id: string;
  number: number;
  name: string;
  subtitle: string;
  mood: string;
  desc: string;
  plants: string[];
  lookFor: string;
  peace: string;
  images: string[];
  chipColors: string[];
}

const { id, number, name, desc, plants, images, chipColors } = Astro.props;

type ChipColor = 'lime' | 'sun' | 'peach' | 'pink' | 'sky' | 'violet';
const padded = String(number).padStart(2, '0');
---

<article class="stop-section reveal" id={id} aria-label={`Stop ${number}: ${name}`}>

  <div class="stop-img-placeholders" aria-hidden="true">
    {images.map(img => (
      <div class="stop-img-placeholder">{img.replace(/-/g, ' ')}</div>
    ))}
  </div>

  <span class="stop-kicker">stop {padded}</span>
  <h2 class="stop-title">{name}</h2>
  <p class="stop-desc">{desc}</p>

  <div class="chips" aria-label={`Plants at stop ${number}`}>
    {plants.map((plant, i) => (
      <PlantChip label={plant} color={chipColors[i % chipColors.length] as ChipColor} />
    ))}
  </div>

  <LikeButton stopId={id} label={name} />

</article>
