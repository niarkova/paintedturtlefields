<section style="padding:var(--space-9) 0;" aria-label="About Nina">
  <div class="section-inner">
    <div class="about-inner reveal">
      <div class="about-photo-wrap">
        <div class="about-photo-placeholder">Nina</div>
        <img src="/images/bee.png" class="about-photo-bee" alt="" aria-hidden="true" width="44" loading="lazy" />
      </div>
      <div class="about-content">
        <h2 class="about-name">Hi, I'm <em>Nina</em></h2>
        <p class="about-bio">
          This garden in Underhill, Vermont has been growing for several years into a mix
          of practical and peaceful spaces — flowers, herbs, vegetables, berries, trees,
          stone beds, shade, and places to sit. Some areas are mature and full, while others
          are still becoming what they want to be. For the tour, the goal is to celebrate that mix:
          the useful and the beautiful, the colorful and the quiet, the planned and the surprising.
        </p>
        <p class="about-say-hi">say hi!</p>
        <div class="social-btns">
          <a href="#" class="social-btn social-btn--fb" aria-label="Nina on Facebook">📘 Facebook</a>
          <a href="#" class="social-btn social-btn--ig" aria-label="Nina on Instagram">📷 Instagram</a>
        </div>
      </div>
    </div>
  </div>
</section>
